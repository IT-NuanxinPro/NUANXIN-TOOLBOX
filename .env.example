# 本地开发时复制为 .env.local；该文件已被 Git 忽略。
# 密钥只允许由 server.ts 读取，禁止使用 VITE_ 前缀。
AI_API_KEY="YOUR_GROQ_API_KEY"

# 默认使用 Groq 的 OpenAI 兼容接口，可替换为 OpenRouter 等兼容平台。
AI_BASE_URL="https://api.groq.com/openai/v1"
AI_MODEL="qwen/qwen3-32b"

# 每个来源每天最多调用次数，以及允许访问代理的前端地址。
AI_DAILY_LIMIT="20"
AI_ALLOWED_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"
AI_PROXY_PORT="3001"

# 部署独立代理后，前端构建时填写公开的代理地址；这不是密钥。
VITE_AI_API_URL="/api/ai/chat"
APP_URL="http://localhost:3000"
